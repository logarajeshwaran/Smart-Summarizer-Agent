# ── Required ──────────────────────────────────────────────────────────────
# Get this from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────
# Set to "true" to include raw agent response in API output (dev only)
DEBUG=false

# Port (Cloud Run sets this automatically)
PORT=8080
