# ── Required ──────────────────────────────────────────────────────────────
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────
# Set to "true" to include raw agent response in API output (dev only)
DEBUG=false

# Port (Cloud Run sets this automatically)
PORT=8080
